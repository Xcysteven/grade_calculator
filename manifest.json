{
  "manifest_version": 3,
  "name": "UCSD Grade Dashboard",
  "version": "0.1.0",
  "description": "Estimate UCSD DSC course grades from Gradescope and run local what-if grade simulations.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "UCSD Grade Dashboard",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.gradescope.com/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://dsc10.com/*",
    "https://dsc20.com/*",
    "https://dsc30.com/*",
    "https://dsc40a.com/*",
    "https://dsc40b.com/*",
    "https://dsc80.com/*",
    "https://dsc90.com/*",
    "https://dsc95.com/*",
    "https://dsc96.com/*",
    "https://dsc100.com/*",
    "https://dsc100.org/*",
    "https://dsc102.com/*",
    "https://dsc103.com/*",
    "https://dsc106.com/*",
    "https://dsc140a.com/*",
    "https://dsc140b.com/*",
    "https://dsc148.com/*",
    "https://dsc155.com/*",
    "https://dsc160.com/*",
    "https://dsc167.com/*",
    "https://dsc170.com/*",
    "https://dsc180a.com/*",
    "https://dsc180b.com/*",
    "https://dsc190.com/*",
    "https://dsc191.com/*",
    "https://dsc10.org/*",
    "https://dsc20.org/*",
    "https://dsc30.org/*",
    "https://dsc40a.org/*",
    "https://dsc40b.org/*",
    "https://dsc80.org/*",
    "https://dsc90.org/*",
    "https://dsc95.org/*",
    "https://dsc96.org/*",
    "https://dsc102.org/*",
    "https://dsc103.org/*",
    "https://dsc106.org/*",
    "https://dsc140a.org/*",
    "https://dsc140b.org/*",
    "https://dsc148.org/*",
    "https://dsc155.org/*",
    "https://dsc160.org/*",
    "https://dsc167.org/*",
    "https://dsc170.org/*",
    "https://dsc180a.org/*",
    "https://dsc180b.org/*",
    "https://dsc190.org/*",
    "https://dsc191.org/*",
    "https://dsc-courses.github.io/*",
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/dsc-courses/*"
  ]
}
