{
  "manifest_version": 3,
  "name": "UCSD Grade Dashboard",
  "version": "0.0.1",
  "description": "Calculate grades for UCSD DSC courses (Gradescope + DSC websites + Canvas).",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.gradescope.com/*", "https://canvas.ucsd.edu/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage", 
    "scripting" 
  ],
  "host_permissions": [
    "https://www.gradescope.com/*",
    "https://canvas.ucsd.edu/*"
  ]
}